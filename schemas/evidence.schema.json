{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Hangsau/psychology-knowledge-atlas/schemas/evidence.schema.json",
  "title": "Claim evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "record_type", "claim_id", "source_id", "locator", "evidence_level", "status", "publishable", "provenance"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "record_type": {"const": "evidence"},
    "claim_id": {"type": "string"},
    "source_id": {"type": "string"},
    "locator": {"type": "string", "minLength": 1},
    "evidence_level": {"enum": ["fulltext_direct", "fulltext_indirect", "abstract_only", "metadata_only"]},
    "status": {"enum": ["unverified", "retrieved", "verified", "disputed", "excluded"]},
    "publishable": {"type": "boolean"},
    "provenance": {"enum": ["legacy_seed", "reference_system", "source_derived", "manual"]},
    "summary": {"type": "string"},
    "short_quote": {"type": "string"}
  }
}
