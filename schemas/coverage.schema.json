{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Hangsau/psychology-knowledge-atlas/schemas/coverage.schema.json",
  "title": "Reference-system candidate coverage decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "record_type", "reference_system_id", "candidate_id", "candidate_label", "decision", "reason", "status", "publishable", "provenance"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "record_type": {"const": "coverage"},
    "reference_system_id": {"type": "string"},
    "candidate_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "candidate_label": {"type": "string", "minLength": 1},
    "decision": {"enum": ["included", "merged", "excluded", "pending"]},
    "reason": {"type": "string", "minLength": 1},
    "target_entity_id": {"type": "string"},
    "status": {"enum": ["unverified", "retrieved", "verified", "disputed", "excluded"]},
    "publishable": {"type": "boolean"},
    "provenance": {"enum": ["legacy_seed", "reference_system", "source_derived", "manual"]}
  }
}
